{
  "name": "hewg",
  "version": "0.0.1",
  "description": "Annotation-based analyzer for agent-friendly TypeScript.",
  "type": "module",
  "bin": {
    "hewg": "bin/hewg.js"
  },
  "files": [
    "bin",
    "dist",
    "src",
    "stdlib",
    "README.md"
  ],
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "bun run build:linux",
    "build:linux": "bun build --compile --target=bun-linux-x64 --outfile=dist/hewg src/cli.ts",
    "build:darwin-x64": "bun build --compile --target=bun-darwin-x64 --outfile=dist/hewg-darwin-x64 src/cli.ts",
    "build:darwin-arm64": "bun build --compile --target=bun-darwin-arm64 --outfile=dist/hewg-darwin-arm64 src/cli.ts",
    "gen:docs": "bun run scripts/gen-diagnostics-doc.ts",
    "gen:effect-map-doc": "bun run scripts/gen-effect-map-doc.ts",
    "bench": "bun run bench/harness.ts",
    "bench:analyze": "bun run bench/analyze.ts"
  },
  "dependencies": {
    "cac": "^6.7.14",
    "ts-morph": "^24.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.1.10",
    "ajv": "^8.18.0",
    "ajv-draft-04": "^1.0.0",
    "ajv-formats": "^3.0.1",
    "js-tiktoken": "^1.0.21",
    "typescript": "^5.6.3"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
